         xmlns:md="http://iec.ch/TC57/61970-552/ModelDescription/1#"
         xml:base="minimal_cim.xml">
  <md:FullModel rdf:about="minimal">
    <md:Model.profile>http://entsoe.eu/CIM/EquipmentCore/3/1</md:Model.profile>
